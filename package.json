{
  "name": "@prmichaelsen/agentbase-core",
  "version": "0.1.2",
  "description": "Shared service infrastructure for agentbase projects — BaseService, auth, Firebase wrappers, logging, and common utilities",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./services": {
      "import": "./dist/services/index.js",
      "types": "./dist/services/index.d.ts"
    },
    "./lib": {
      "import": "./dist/lib/index.js",
      "types": "./dist/lib/index.d.ts"
    },
    "./lib/auth": {
      "import": "./dist/lib/auth/index.js",
      "types": "./dist/lib/auth/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    },
    "./config": {
      "import": "./dist/config/index.js",
      "types": "./dist/config/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage && npx tsx scripts/build-banner.ts",
    "generate:types": "npx openapi-typescript openapi.yaml -o src/client/api-types.generated.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agentbase",
    "service",
    "firebase",
    "auth"
  ],
  "author": "prmichaelsen",
  "license": "MIT",
  "peerDependencies": {
    "@prmichaelsen/firebase-admin-sdk-v8": ">=2.0.0",
    "firebase": ">=10.0.0",
    "jsonwebtoken": ">=9.0.0"
  },
  "peerDependenciesMeta": {
    "@prmichaelsen/firebase-admin-sdk-v8": {
      "optional": true
    },
    "firebase": {
      "optional": true
    },
    "jsonwebtoken": {
      "optional": true
    }
  },
  "devDependencies": {
    "@prmichaelsen/firebase-admin-sdk-v8": "^2.8.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "chalk": "^5.6.2",
    "figlet": "^1.11.0",
    "firebase": "^10.14.1",
    "gradient-string": "^3.0.0",
    "jsonwebtoken": "^9.0.3",
    "openapi-typescript": "^7.13.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  }
}
